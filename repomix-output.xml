        {/* RIGHT SIDE: LOGIN FORM (Takes exactly 40% on Desktop) */}
        <div className="w-full md:w-[40%] p-8 sm:p-12 md:p-10 lg:p-12 flex flex-col justify-center bg-white relative z-20">
          
          {/* Mobile Logo (Visible only on small screens) */}
