function toLocalDateString(d: Date) { 
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}
// Hooks
import { useEventExtraction } from "./hooks/useEventExtraction";
