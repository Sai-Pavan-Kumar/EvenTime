    const query = `name=${encodeURIComponent(name)}&score=${score}&rank=${rank}&image=${encodeURIComponent(image)}`;
    const expectedSig = await generateHMAC(query);
    
    if (sig !== expectedSig) {
      return new Response('Forbidden', { status: 403 });
